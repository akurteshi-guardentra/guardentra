# Local-first development. Copy to .env.local and fill values.
# See docs/ENVIRONMENTS.md for Firebase project aliases (demo / dev / staging / prod).
APP_ENV=development

# Gemini — used by Express /api/ai and (temporarily) some client pages
GEMINI_API_KEY=

# Stripe — test keys for local/staging; leave empty to use mock checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: override listen port (Cloud Run / App Hosting set PORT automatically; local default 8080)
# PORT=8080
PORT=8080

# Firebase client (optional). When unset, falls back to firebase-applet-config.json (demo).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIRESTORE_DATABASE_ID=